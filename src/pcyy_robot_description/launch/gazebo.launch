<launch>
  <arg name="xacro_file" default="$(find pcyy_robot_description)/urdf/simple_robot.xacro" />
  <arg name="paused" default="false" />
  <arg name="use_sim_time" default="true" />
  <arg name="gui" default="true" />
  <arg name="headless" default="false" />
  <arg name="debug" default="false" />

  <!-- 启动 Gazebo 空世界 -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="paused" value="$(arg paused)" />
    <arg name="use_sim_time" value="$(arg use_sim_time)" />
    <arg name="gui" value="$(arg gui)" />
    <arg name="headless" value="$(arg headless)" />
    <arg name="debug" value="$(arg debug)" />
  </include>

  <!-- 从 xacro 生成 robot_description -->
  <param name="robot_description" command="$(find xacro)/xacro $(arg xacro_file)" />

  <!-- 发布 TF（用于可视化/调试） -->
  <node pkg="robot_state_publisher" type="robot_state_publisher" name="robot_state_publisher" output="screen" />

  <!-- 将模型实体注入 Gazebo -->
  <node pkg="gazebo_ros" type="spawn_model" name="spawn_simple_robot"
        args="-urdf -param robot_description -model simple_robot -x 0 -y 0 -z 0.05"
        output="screen" />
</launch>
