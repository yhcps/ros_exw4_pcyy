<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <material name="wheel_black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>

  <xacro:macro name="wheel_module" params="side sign">
    <link name="wheel_${side}_link">
      <xacro:cylinder_inertial mass="${wheel_mass}" radius="${wheel_radius}" length="${wheel_width}"/>
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="wheel_black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
    </link>

    <joint name="wheel_${side}_joint" type="revolute">
      <origin xyz="0 ${sign*wheel_y_offset} ${wheel_radius}" rpy="0 0 0"/>
      <parent link="base_link"/>
      <child link="wheel_${side}_link"/>
      <axis xyz="0 1 0"/>
      <limit lower="-1000" upper="1000" effort="20" velocity="20"/>
      <dynamics damping="0.1" friction="0.05"/>
    </joint>
  </xacro:macro>
</robot>
